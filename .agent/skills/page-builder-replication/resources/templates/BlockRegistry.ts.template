import { ReactNode, ComponentType, LazyExoticComponent } from 'react';

/**
 * BlockDefinition interface defines the structure of a page builder block.
 */
export interface BlockDefinition {
    type: string;
    label: string;
    icon?: ReactNode;
    renderer: LazyExoticComponent<ComponentType<any>> | ComponentType<any>;
    editor: LazyExoticComponent<ComponentType<any>> | ComponentType<any>;
}

/**
 * BlockRegistry maintains a singleton map of all available block types.
 * This pattern allows for easy addition of new blocks without modifying the core renderer.
 */
class BlockRegistry {
    private blocks: Map<string, BlockDefinition> = new Map();

    /**
     * Register a new block type.
     * Use this in a central registration file (e.g., registerBlocks.tsx).
     */
    register(definition: BlockDefinition) {
        if (this.blocks.has(definition.type)) {
            console.warn(`Block type "${definition.type}" is already registered. Overwriting.`);
        }
        this.blocks.set(definition.type, definition);
    }

    /**
     * Retrieve a block definition by its type.
     */
    get(type: string): BlockDefinition | undefined {
        return this.blocks.get(type);
    }

    /**
     * Returns an array of all registered block definitions.
     * Useful for building "Add Block" menus.
     */
    getAll(): BlockDefinition[] {
        return Array.from(this.blocks.values());
    }

    /**
     * Check if a block type is registered.
     */
    has(type: string): boolean {
        return this.blocks.has(type);
    }
}

export const blockRegistry = new BlockRegistry();
export default blockRegistry;
